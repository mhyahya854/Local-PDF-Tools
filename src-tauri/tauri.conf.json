{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PDF Powerhouse",
  "version": "0.1.0",
  "identifier": "com.local.pdfpowerhouse",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:8080",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PDF Powerhouse",
        "width": 1280,
        "height": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
